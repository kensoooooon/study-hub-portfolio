# === Environment ===
ENV=local

# === Django ===
DJANGO_SECRET_KEY=your-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# === GCP ===
GCP_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_PROJECT_ID_FALLBACK=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
LINE_KMS_KEY_RESOURCE=projects/<project-id>/locations/asia-northeast1/keyRings/<key-ring>/cryptoKeys/<key-name>

# === LINE ===
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# === OpenAI ===
OPENAI_API_KEY=your-openai-api-key

# === Database (local) ===
DATABASE_PASSWORD=your-db-password
LOCAL_DB_NAME=my-local-db
LOCAL_DB_USER=db-user

# === Database (production) ===
DJANGO_DB_ENGINE=django.db.backends.postgresql
DJANGO_DB_NAME=your-db-name
DJANGO_DB_USER=your-db-user
DJANGO_DB_PASSWORD=your-db-password
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432

# === Mail ===
APP_NAME=StudyHub
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_NOREPLY_ADDRESS=noreply@example.com
EMAIL_CONTACT_ADDRESS=contact@example.com

# === Public base URL ===
APP_PUBLIC_BASE_URL_PROD=https://your-app.example.com

# === Defaults ===
TEACHER_DEFAULT_PASSWORD=changeme
STUDENT_DEFAULT_PASSWORD=changeme

# === Pub/Sub ===
PUBSUB_SUBSCRIPTION=your-subscription-name

# === Project ID ===
GCP_PROJECT_ID_FALLBACK=your-gcp-project-id

# === OIDC ===
OIDC_AUDIENCE=https://your-app.example.com